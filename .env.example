# Sao chép file này thành .env.local rồi điền giá trị thật.
# QUY TẮC: chỉ biến có tiền tố NEXT_PUBLIC_ mới lộ ra trình duyệt.
# Mọi biến mới thêm vào đây PHẢI khai báo trong src/config/env.ts (Zod).

# Public (lộ ra client)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_STORE_LAT=
NEXT_PUBLIC_STORE_LNG=

# Server-side secret (KHÔNG để lộ ra client)
# DATABASE_URL=
